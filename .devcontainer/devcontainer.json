{
  "name": "Preceptor's Primer",

  // TODO — revisit before next term: do students actually get the prebuild?
  // Codespaces prebuilds ARE enabled on PPBDS/codespace-starter (Settings →
  // Codespaces), which makes launches FROM THIS REPO fast. But a prebuild
  // attaches to this repo only. If students get their own copy via "Use
  // this template" or GitHub Classroom, those are fresh repos with NO
  // prebuild — their first launch builds on-demand (slow). Need to decide
  // the distribution model: (a) students launch Codespaces directly from
  // codespace-starter → they benefit from the prebuild; or (b) students
  // work in a copy → they don't, and we'd need another plan (prebuilds on
  // the assignment repos, or just accept the cold first start).

  // PPBDS student image, pinned to v0.3.0. Bumping is a deliberate
  // edit to this line — never use `:latest` in student-facing config,
  // since it would float silently with every push to PPBDS/devcontainers.
  //
  // Bakes in: gh, quarto, arf (Rust R console), httpgd, pak,
  // tutorial.helpers, vscode.tutorials, and three AI coding CLIs:
  //   - claude  (Anthropic)         — needs ANTHROPIC_API_KEY
  //   - gemini  (Google)            — free tier available, else GOOGLE_API_KEY
  //   - aider   (multi-provider)    — DeepSeek/OpenRouter for cheap models
  // Students set the API keys for whichever tools they use as Codespaces
  // user secrets at https://github.com/settings/codespaces. See
  // https://github.com/PPBDS/devcontainers for details.
  //
  // Note for instructors: `gh` is preinstalled and authenticated against
  // the Codespace's home repo via the built-in GITHUB_TOKEN. Pushing to
  // OTHER repos (e.g., cloning a sibling package and pushing to it)
  // requires a one-time `gh auth login` per Codespace — that's by design,
  // not a bug. The built-in token is read-mostly outside the home repo.
  "image": "ghcr.io/ppbds/devcontainers/student:0.3.0",

  // Refresh the fast-moving PPBDS course packages to the latest commit on
  // each one's default branch, every time a Codespace is created. The
  // image (see student/Dockerfile in PPBDS/devcontainers) BAKES these too,
  // which (1) pre-installs all transitive deps so this is a quick single-
  // package refresh, not a cold build, and (2) leaves a working fallback
  // version if GitHub is unreachable here — a failed postCreateCommand
  // doesn't block the Codespace from opening.
  //
  // This MUST be postCreateCommand, not onCreate/updateContentCommand:
  // those run at prebuild time and would re-freeze "latest" at the
  // prebuild, recreating the manual-update problem this solves. postCreate
  // runs live when each Codespace is created, even from a prebuild.
  //
  // No upgrade = TRUE: deps are already baked at known-good versions, so
  // this refreshes only the named packages and avoids re-churning the
  // learnr/knitr/xfun chain (see the xfun ABI note in student/Dockerfile).
  //
  // ACCEPTED RISK — blast radius: tracking GitHub HEAD means a bad commit
  // to either package breaks EVERY new Codespace at once, with no pinned
  // image to shield us. We accept this in exchange for fast bug-fix
  // delivery. The mitigation is operational, not config: if new Codespaces
  // start failing, revert the offending commit in the upstream PPBDS/<pkg>
  // repo ASAP — that fixes all subsequent creates immediately, with no
  // image rebuild or pin bump needed. (If this ever bites too often, switch
  // to pinning a tested release tag here and bumping it deliberately.)
  "postCreateCommand": "R -q -e 'pak::pkg_install(c(\"PPBDS/tutorial.helpers\", \"PPBDS/vscode.tutorials\"), ask = FALSE)'",

  // Visual "setup complete" signal for students. In the devcontainer
  // lifecycle, VS Code extensions are installed BEFORE this hook runs, so
  // by the time this banner prints, everything (extensions, R, Quarto,
  // the AI CLIs) is genuinely ready — it can't fire early and mislead.
  // Runs on every container start (it's cheap), which also reassures
  // students each time they resume a Codespace. If a real setup step is
  // ever needed, add it ABOVE the banner so the banner stays last.
  "postStartCommand": "echo '' && echo '════════════════════════════════════════════' && echo '' && echo '   ✅  YOUR CODESPACE IS READY' && echo '' && echo '   All extensions and tools are installed.' && echo '   You can start working now.' && echo '' && echo '════════════════════════════════════════════' && echo ''",

  "customizations": {
    "vscode": {

      // Extensions students actually need
      "extensions": [
        "reditorsupport.r",
        "quarto.quarto",
        "PPBDS.vscode-r-tutorials",
        "google.gemini-cli-vscode-ide-companion",
        "ritwickdey.LiveServer",
        "tomoki1207.pdf",
        "mechatroner.rainbow-csv"
      ],

      "settings": {

        // Use arf (Rust-based R console) instead of the default R terminal.
        // The image installs arf at this exact path; if it ever moves,
        // update both this setting and base/Dockerfile in PPBDS/devcontainers.
        "r.rterm.linux": "/home/rstudio/.cargo/bin/arf",

        // Required for arf-style consoles to handle pasted code correctly.
        "r.bracketedPaste": true,

        // Render plots inside VS Code via the httpgd graphics device
        // instead of opening an external window (which doesn't work in Codespaces).
        "r.plot.useHttpgd": true,

        // Prevent VS Code from nagging to relaunch the terminal when
        // environment variables change.
        "terminal.integrated.environmentChangesRelaunch": false,

        // NOTE — we want to suppress VS Code's Welcome / "Get Started" tab,
        // but there is currently NO way to do it from here. The setting that
        // controls it, workbench.startupEditor, is application-scoped: VS
        // Code only honors it in per-user settings and deliberately IGNORES
        // it in workspace/remote/devcontainer settings. So a
        // "workbench.startupEditor": "none" line here is a confirmed no-op in
        // Codespaces (see microsoft/vscode#134073, #160635, #242243) — it was
        // removed rather than left as dead config that looks like it works.
        // Revisit if that bug is ever fixed. Workaround for now: ship our own
        // welcome doc and open it via postAttachCommand so students land on
        // our content instead of VS Code's generic Welcome tab.

        // Auto-stage all changes on commit so students don't get a confusing
        // dialog asking whether to stage files.
        "git.enableSmartCommit": true,

        // Don't prompt "are you sure?" before push/pull.
        "git.confirmSync": false,

        // Don't fetch from the remote in the background. Keeps things
        // predictable and avoids confusing status bar changes.
        "git.autofetch": false,

        // Auto-save files after a short delay. Prevents the #1 beginner
        // problem: "my code isn't working" because the file wasn't saved.
        "files.autoSave": "afterDelay",

        // Stop VS Code from suggesting random extensions students don't need.
        "extensions.ignoreRecommendations": true,

        // Prevent the "open repository in parent folder?" prompt that
        // confuses students who don't understand nested git repos.
        "git.openRepositoryInParentFolders": "never",

        // Prevent extensions from opening walkthrough tabs on first install.
        "workbench.welcomePage.walkthroughs.openOnInstall": false,

        // Wrap long lines so students don't think code disappeared
        // off the right edge of the screen.
        "editor.wordWrap": "on",

        // Disable the minimap — beginners don't use it and it wastes
        // screen space, especially on Chromebooks and small laptops.
        "editor.minimap.enabled": false,

        // Prevent VS Code from opening files in "preview" mode (italic
        // tab title) which silently replaces the tab when another file
        // is clicked. Beginners think their file vanished.
        "workbench.editor.enablePreview": false
      }
    }
  }
}
